FROM python:3.11-slim

# Cloud inference proxy — no GPU, no ML frameworks.
# hf_serve.py forwards requests to a private HF vLLM Inference Endpoint.
# Only needs httpx, fastapi, uvicorn, and python-dotenv.

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.model.txt .
RUN pip install --no-cache-dir -r requirements.model.txt

COPY . .

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

# Adapter mount point (kept for /adapters listing endpoint compatibility)
VOLUME /adapters

EXPOSE 8001

CMD ["python", "-m", "model_server.hf_serve"]
