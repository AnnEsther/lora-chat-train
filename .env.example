# ── Hugging Face ──────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_token_here
HF_USERNAME=your_hf_username

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1
S3_BUCKET=your-lora-bucket

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lora:lora@localhost:5432/lora
POSTGRES_USER=lora
POSTGRES_PASSWORD=lora
POSTGRES_DB=lora

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Model ─────────────────────────────────────────────────────────────────────
BASE_MODEL=meta-llama/Llama-3.2-1B-Instruct
# Path where adapters are loaded from (relative to model_server container)
ADAPTER_DIR=/adapters/current

# ── HF Dedicated Inference Endpoint (hf_serve.py) ────────────────────────────
# Create a private Dedicated Inference Endpoint at https://endpoints.huggingface.co
# pointing at BASE_MODEL with framework=vLLM, visibility=Private.
# Paste the endpoint URL below. Leave blank to use local_gpu_serve.py instead.
HF_ENDPOINT_URL=https://your-endpoint-name.us-east-1.aws.endpoints.huggingface.cloud
# Model ID sent in the vLLM /v1/chat/completions request body.
# Must match the model deployed on the endpoint. Defaults to BASE_MODEL if not set.
HF_ENDPOINT_MODEL=meta-llama/Llama-3.2-1B-Instruct

# ── Session budget ────────────────────────────────────────────────────────────
MAX_SESSION_TOKENS=4096
PRE_SLEEP_THRESHOLD=512

# ── API ───────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
SECRET_KEY=change_me_to_a_long_random_string

# ── Training ──────────────────────────────────────────────────────────────────
# HF Inference Endpoint or Space URL used to trigger training jobs
HF_TRAINING_ENDPOINT=https://api.endpoints.huggingface.co/v2/endpoint/your_endpoint

# Minimum curated samples required to launch training
MIN_TRAINING_SAMPLES=10

# Number of consecutive transcript turns per training segment (sliding window)
EXTRACTION_WINDOW_SIZE=4

# LoRA hyperparameters
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LORA_TARGET_MODULES=q_proj,v_proj

# SFT training args
TRAIN_EPOCHS=3
TRAIN_BATCH_SIZE=4
TRAIN_GRAD_ACCUM=4
TRAIN_LR=2e-4
MAX_SEQ_LENGTH=512

LOCAL_OUTPUT_DIR=
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MODEL_SERVER_URL=http://localhost:8001

